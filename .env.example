# ==== Database ====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_saas?schema=public"

# ==== Redis (optional, used by throttler/refresh-token cache) ====
REDIS_URL="redis://localhost:6379"

# ==== API ====
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ==== JWT ====
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES="30d"

# ==== Bootstrap admin (used by seed) ====
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="Admin@12345"

# ==== Default credit gift on register ====
DEFAULT_REGISTER_CREDITS=1000

# ==== AI providers (default OpenAI-compatible) ====
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""

OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY=""

SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_API_KEY=""


# ==== WeChat Pay v3 ====
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
# Authorization 头的 serial_no 字段值，二选一：
#   - 证书模式: 证书序列号 (openssl x509 -in apiclient_cert.pem -noout -serial)
#   - 新公钥模式: PUB_KEY_ID_xxx
WECHAT_PUB_KEY_ID=""
# 商户私钥 PEM 路径 (apiclient_key.pem, 跟你的证书或上传的公钥配对)
WECHAT_PRIVATE_KEY_PATH="./apiclient_key.pem"
# 微信平台公钥 PEM 路径 (商户平台->API安全->平台公钥下载, 用于验签微信响应/通知)
WECHAT_PLATFORM_PUB_KEY_PATH="./wechatpay_pub_key.pem"
# APIv3 密钥 32 字符 (商户平台->账户中心->API安全->APIv3密钥, 自己设置, 用于 AES-GCM 解密回调)
WECHAT_API_V3_KEY=""
# 公网 HTTPS 回调地址。本地测试用 ngrok: https://xxx.ngrok-free.app/api/payments/wechat/notify
WECHAT_NOTIFY_URL=""

# ==== Alipay (placeholder, 暂未实现) ====
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# ==== Google OAuth (复用 auth-center 的凭证；redirect URI 必须在 Google Console 加白名单) ====
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"
WEB_BASE_URL="http://localhost:5173"

# ==== WeChat 开放平台（PC 扫码登录）====
# 1. 申请：https://open.weixin.qq.com → 网站应用（需企业认证 ¥300/年）
# 2. 后台填的"授权回调域名"必须等于下方 REDIRECT_URI 的域名部分
# 3. 不能用 localhost；本地测试请用 ngrok / cloudflare tunnel
WECHAT_OPEN_APP_ID=""
WECHAT_OPEN_APP_SECRET=""
WECHAT_OPEN_REDIRECT_URI="http://localhost:4000/api/auth/wechat/callback"

# ==== SMS 短信验证码登录 ====
# dev: 不调用任何厂商, 把验证码打到 API 日志里, 用于本地联调
# aliyun / tencent: 走对应厂商, 填下方对应密钥即可
SMS_PROVIDER="dev"
SMS_CODE_LENGTH=6
SMS_CODE_TTL_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60

# 阿里云短信 (SMS_PROVIDER=aliyun 时使用)
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# 腾讯云短信 (SMS_PROVIDER=tencent 时使用)
TENCENT_SMS_SECRET_ID=""
TENCENT_SMS_SECRET_KEY=""
TENCENT_SMS_SDK_APP_ID=""
TENCENT_SMS_SIGN_NAME=""
TENCENT_SMS_TEMPLATE_ID=""

# ==== Frontend (Vite) ====
VITE_API_BASE_URL="http://localhost:4000"
VITE_SITE_NAME="AI SaaS Starter"
