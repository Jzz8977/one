# ==== Database ====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_saas?schema=public"

# ==== Redis (optional, used by throttler/refresh-token cache) ====
REDIS_URL="redis://localhost:6379"

# ==== API ====
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ==== JWT ====
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES="30d"

# ==== Bootstrap admin (used by seed) ====
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="Admin@12345"

# ==== Default credit gift on register ====
DEFAULT_REGISTER_CREDITS=1000

# ==== AI providers (default OpenAI-compatible) ====
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""

OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY=""

SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_API_KEY=""

# ==== Payment (placeholder) ====
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""

ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# ==== Frontend (Vite) ====
VITE_API_BASE_URL="http://localhost:4000"
VITE_SITE_NAME="AI SaaS Starter"
